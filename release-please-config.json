{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "pdfium-node packages",
      "components": [
        "pdfium-node",
        "pdfium-node-darwin-arm64",
        "pdfium-node-linux-x64-gnu"
      ]
    }
  ],
  "separate-pull-requests": false,
  "packages": {
    "packages/pdfium-node": {
      "component": "pdfium-node",
      "release-type": "node"
    },
    "packages/pdfium-node-darwin-arm64": {
      "component": "pdfium-node-darwin-arm64",
      "release-type": "node"
    },
    "packages/pdfium-node-linux-x64-gnu": {
      "component": "pdfium-node-linux-x64-gnu",
      "release-type": "node"
    }
  }
}
