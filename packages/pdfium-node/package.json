{
  "name": "pdfium-node",
  "version": "1.0.0",
  "description": "Native PDFium access for Node.js.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/pdfium-node.git",
    "directory": "packages/pdfium-node"
  },
  "bugs": {
    "url": "https://github.com/sebastian-software/pdfium-node/issues"
  },
  "homepage": "https://github.com/sebastian-software/pdfium-node#readme",
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "pdfium-node-darwin-arm64": "1.0.0",
    "pdfium-node-linux-x64-gnu": "1.0.0"
  },
  "license": "MIT"
}
